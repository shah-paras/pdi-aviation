# Mapbox (already required)
VITE_MAPBOX_TOKEN=

# Supabase — client-side (safe to expose in the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe — publishable key only (safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=

# Razorpay — key ID only (safe to expose; secret stays server-side)
VITE_RAZORPAY_KEY_ID=

# -----------------------------------------------------------------------------
# Server-side secrets — DO NOT commit these.
# Set with `supabase secrets set NAME=value` once per environment, not in .env.
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_ANNUAL=price_...
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PLAN_MONTHLY=plan_...
# RAZORPAY_PLAN_ANNUAL=plan_...
# SITE_URL=https://your-prod-domain.com
